BOT_TOKEN=your_telegram_bot_token_here
DB_PATH=uzum_bot.db
PORT=8080

# ── AI advisor (pick at least one; priority: Groq -> OpenRouter -> Gemini) ──
# Recommended easy free default:
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative providers:
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Force a specific provider (optional): groq | openrouter | gemini
AI_PROVIDER=

# Render free-tier keep-alive. Render sets RENDER_EXTERNAL_URL automatically on deploy
# (e.g. https://your-service.onrender.com). When set, the bot self-pings {RENDER_EXTERNAL_URL}/ping
# every 10 minutes so the web service does not spin down. Leave empty for local runs (self-ping no-ops).
RENDER_EXTERNAL_URL=


# ── Competitor price scraping (optional) ──
# Uzum soft-blocks datacenter/cloud IPs (captcha + geo), so price fetch can fail
# from a cloud host (e.g. Render). Route the competitor scraping GETs through a
# UZ/residential proxy so automatic price retrieval works. Format:
#   http://user:pass@host:port   (leave empty to fetch directly / no proxy)
UZUM_PROXY=
