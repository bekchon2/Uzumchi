BOT_TOKEN=your_telegram_bot_token_here
DB_PATH=uzum_bot.db
PORT=8080
GEMINI_API_KEY=your_gemini_api_key_here

# Render free-tier keep-alive. Render sets RENDER_EXTERNAL_URL automatically on deploy
# (e.g. https://your-service.onrender.com). When set, the bot self-pings {RENDER_EXTERNAL_URL}/ping
# every 10 minutes so the web service does not spin down. Leave empty for local runs (self-ping no-ops).
RENDER_EXTERNAL_URL=
